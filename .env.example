# ─── Matrix / Synapse ────────────────────────────────────────────────────────
SYNAPSE_SERVER_NAME=localhost
MATRIX_SERVER_NAME=localhost
SYNAPSE_DB_PASSWORD=change-this-strong-password
MATRIX_ADMIN_PASSWORD=change-this-admin-password
HERMES_BOT_PASSWORD=change-this-bot-password

# Generated by setup.sh — leave blank, setup.sh will populate these:
MATRIX_AS_TOKEN=
MATRIX_HS_TOKEN=
HERMES_MATRIX_ACCESS_TOKEN=
HERMES_MATRIX_ROOM_ID=

# ─── Hermes ──────────────────────────────────────────────────────────────────
HERMES_API_KEY=change-this-to-a-strong-random-key
HERMES_BASE_URL=http://nomad_ollama:11434/v1
HERMES_MODEL=llama3.1:8b

# ─── Orchestrator ────────────────────────────────────────────────────────────
PORT=4000
AI_RATE_LIMIT_PER_MINUTE=10
TRANSCRIPT_CONTEXT_WINDOW=20

# ─── NOMAD ───────────────────────────────────────────────────────────────────
OLLAMA_HOST=0.0.0.0

# ─── Port Reference ─────────────────────────────────────────────────────────
# Element Web    → http://localhost:8080
# NOMAD CC       → http://localhost:8081  (remapped from 8080 via override)
# Synapse        → http://localhost:8008
# Orchestrator   → http://localhost:4000
# Hermes Agent   → http://localhost:8642
# Ollama         → http://localhost:11434
# Qdrant         → http://localhost:6333
# PostgreSQL     → localhost:5432
# Redis          → localhost:6379
